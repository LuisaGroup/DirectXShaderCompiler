#include <vk/opcode_selector.h>

// ============================================================================
// Inline-SPIR-V Builtin Declarations
// ============================================================================

// --- OpCreateTensorLayoutNV (5372) ---
// Requires: TensorAddressingNV (5439), SPV_NV_tensor_addressing

template <typename ResultType>
[[vk::ext_instruction(/* OpCreateTensorLayoutNV */ 5372)]]
[[vk::ext_capability(/* TensorAddressingNV */ 5439)]]
[[vk::ext_extension("SPV_NV_tensor_addressing")]]
ResultType __builtin_spv_CreateTensorLayoutNV();

// --- OpTensorLayoutSetDimensionNV (5373) ---

template <typename ResultType>
[[vk::ext_instruction(/* OpTensorLayoutSetDimensionNV */ 5373)]]
[[vk::ext_capability(/* TensorAddressingNV */ 5439)]]
[[vk::ext_extension("SPV_NV_tensor_addressing")]]
ResultType __builtin_spv_TensorLayoutSetDimensionNV(
    ResultType layout, uint dim, uint size);

// --- OpTensorLayoutSetStrideNV (5374) ---

template <typename ResultType>
[[vk::ext_instruction(/* OpTensorLayoutSetStrideNV */ 5374)]]
[[vk::ext_capability(/* TensorAddressingNV */ 5439)]]
[[vk::ext_extension("SPV_NV_tensor_addressing")]]
ResultType __builtin_spv_TensorLayoutSetStrideNV(
    ResultType layout, uint dim, uint stride);

// --- OpTensorLayoutSetBlockSizeNV (5384) ---

template <typename ResultType>
[[vk::ext_instruction(/* OpTensorLayoutSetBlockSizeNV */ 5384)]]
[[vk::ext_capability(/* TensorAddressingNV */ 5439)]]
[[vk::ext_extension("SPV_NV_tensor_addressing")]]
ResultType __builtin_spv_TensorLayoutSetBlockSizeNV(
    ResultType layout, uint dim, uint blockSize);

// --- OpTensorLayoutSliceNV (5375) ---

template <typename ResultType>
[[vk::ext_instruction(/* OpTensorLayoutSliceNV */ 5375)]]
[[vk::ext_capability(/* TensorAddressingNV */ 5439)]]
[[vk::ext_extension("SPV_NV_tensor_addressing")]]
ResultType __builtin_spv_TensorLayoutSliceNV(
    ResultType layout, uint dim, uint offset, uint span);

// --- OpTensorLayoutSetClampValueNV (5376) ---

template <typename ResultType>
[[vk::ext_instruction(/* OpTensorLayoutSetClampValueNV */ 5376)]]
[[vk::ext_capability(/* TensorAddressingNV */ 5439)]]
[[vk::ext_extension("SPV_NV_tensor_addressing")]]
ResultType __builtin_spv_TensorLayoutSetClampValueNV(
    ResultType layout, uint clampValue);

// --- OpCreateTensorViewNV (5377) ---

template <typename ResultType>
[[vk::ext_instruction(/* OpCreateTensorViewNV */ 5377)]]
[[vk::ext_capability(/* TensorAddressingNV */ 5439)]]
[[vk::ext_extension("SPV_NV_tensor_addressing")]]
ResultType __builtin_spv_CreateTensorViewNV();

// --- OpTensorViewSetDimensionNV (5378) ---

template <typename ResultType>
[[vk::ext_instruction(/* OpTensorViewSetDimensionNV */ 5378)]]
[[vk::ext_capability(/* TensorAddressingNV */ 5439)]]
[[vk::ext_extension("SPV_NV_tensor_addressing")]]
ResultType __builtin_spv_TensorViewSetDimensionNV(

// ============================================================================
// Template Function Implementations
// ============================================================================

namespace vk {
namespace nv {

// --- Tensor Layout Functions ---

template <uint Dim, uint ClampMode>
TensorLayout<Dim, ClampMode> createTensorLayout() {
  TensorLayout<Dim, ClampMode> result;
  result._layout =
      __builtin_spv_CreateTensorLayoutNV<
          typename TensorLayout<Dim, ClampMode>::SpirvLayoutType>();
  return result;
}

template <uint Dim, uint ClampMode>
TensorLayout<Dim, ClampMode> tensorLayoutSetDimension(
    TensorLayout<Dim, ClampMode> layout, uint dim, uint size) {
  TensorLayout<Dim, ClampMode> result;
  result._layout =
      __builtin_spv_TensorLayoutSetDimensionNV<
          typename TensorLayout<Dim, ClampMode>::SpirvLayoutType>(
          layout._layout, dim, size);
  return result;
}

template <uint Dim, uint ClampMode>
TensorLayout<Dim, ClampMode> tensorLayoutSetStride(
    TensorLayout<Dim, ClampMode> layout, uint dim, uint stride) {
  TensorLayout<Dim, ClampMode> result;
  result._layout =
      __builtin_spv_TensorLayoutSetStrideNV<
          typename TensorLayout<Dim, ClampMode>::SpirvLayoutType>(
          layout._layout, dim, stride);
  return result;
}

template <uint Dim, uint ClampMode>
TensorLayout<Dim, ClampMode> tensorLayoutSetBlockSize(
    TensorLayout<Dim, ClampMode> layout, uint dim, uint blockSize) {
  TensorLayout<Dim, ClampMode> result;
  result._layout =
      __builtin_spv_TensorLayoutSetBlockSizeNV<
          typename TensorLayout<Dim, ClampMode>::SpirvLayoutType>(
          layout._layout, dim, blockSize);
  return result;
}

template <uint Dim, uint ClampMode>
TensorLayout<Dim, ClampMode> tensorLayoutSlice(
    TensorLayout<Dim, ClampMode> layout, uint dim, uint offset, uint span) {
  TensorLayout<Dim, ClampMode> result;
  result._layout =
      __builtin_spv_TensorLayoutSliceNV<
          typename TensorLayout<Dim, ClampMode>::SpirvLayoutType>(
          layout._layout, dim, offset, span);
  return result;
}

template <uint Dim, uint ClampMode>
TensorLayout<Dim, ClampMode> tensorLayoutSetClampValue(
    TensorLayout<Dim, ClampMode> layout, uint clampValue) {
  TensorLayout<Dim, ClampMode> result;
  result._layout =
      __builtin_spv_TensorLayoutSetClampValueNV<
          typename TensorLayout<Dim, ClampMode>::SpirvLayoutType>(
          layout._layout, clampValue);
  return result;
}

// --- Tensor View Functions ---

template <uint Dim, bool HasDimensions, uint Perm0, uint Perm1>
TensorView<Dim, HasDimensions, Perm0, Perm1> createTensorView() {
  TensorView<Dim, HasDimensions, Perm0, Perm1> result;
  result._view =
      __builtin_spv_CreateTensorViewNV<
          typename TensorView<Dim, HasDimensions, Perm0, Perm1>::SpirvViewType>();
  return result;
}

template <uint Dim, bool HasDimensions, uint Perm0, uint Perm1>
TensorView<Dim, HasDimensions, Perm0, Perm1> tensorViewSetDimension(
    TensorView<Dim, HasDimensions, Perm0, Perm1> view,
    uint dim, uint size) {
  TensorView<Dim, HasDimensions, Perm0, Perm1> result;
  result._view =
      __builtin_spv_TensorViewSetDimensionNV<
          typename TensorView<Dim, HasDimensions, Perm0, Perm1>::SpirvViewType>(
          view._view, dim, size);
  return result;
}

template <uint Dim, bool HasDimensions, uint Perm0, uint Perm1>
TensorView<Dim, HasDimensions, Perm0, Perm1> tensorViewSetStride(
    TensorView<Dim, HasDimensions, Perm0, Perm1> view,
    uint dim, uint stride) {
  TensorView<Dim, HasDimensions, Perm0, Perm1> result;
  result._view =
      __builtin_spv_TensorViewSetStrideNV<
          typename TensorView<Dim, HasDimensions, Perm0, Perm1>::SpirvViewType>(
          view._view, dim, stride);
  return result;
}

template <uint Dim, bool HasDimensions, uint Perm0, uint Perm1>
TensorView<Dim, HasDimensions, Perm0, Perm1> tensorViewSetClip(
    TensorView<Dim, HasDimensions, Perm0, Perm1> view,
    uint rowOffset, uint rowSpan, uint colOffset, uint colSpan) {
  TensorView<Dim, HasDimensions, Perm0, Perm1> result;
  result._view =
      __builtin_spv_TensorViewSetClipNV<
          typename TensorView<Dim, HasDimensions, Perm0, Perm1>::SpirvViewType>(
          view._view, rowOffset, rowSpan, colOffset, colSpan);
  return result;
}

} // namespace nv
} // namespace vk
